---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout>
  <main-canvas
    class="pointer-events-none absolute inset-0 h-full w-full overflow-hidden"
  ></main-canvas>
</BaseLayout>

<script>
  import { Application, Assets, Container, Sprite } from 'pixi.js';

  class MainCanvas extends HTMLElement {
    app: Application | undefined;

    async connectedCallback() {
      const shadow = this.attachShadow({ mode: 'open' });

      this.app = new Application();

      await this.app.init({
        background: '#ffffff',
        backgroundAlpha: 1,
        width: this.clientWidth,
        height: this.clientHeight,
        resolution: window.devicePixelRatio || 1,
        autoDensity: true,
      });

      shadow.appendChild(this.app.canvas);

      const container = new Container();
      this.app.stage.addChild(container);

      const texture = await Assets.load('/images/logo.svg');

      const sprite = container.addChild(new Sprite(texture));
      sprite.scale.set(0.5);

      container.x = this.app.screen.width / 2;
      container.y = this.app.screen.height / 2;

      container.pivot.x = container.width / 2;
      container.pivot.y = container.height / 2;

      const handleResize = () => {
        if (!this.app) return;
        this.app.renderer.resize(this.clientWidth, this.clientHeight);
        container.x = this.app.screen.width / 2;
        container.y = this.app.screen.height / 2;
      };
      window.addEventListener('resize', handleResize);

      this.app.ticker.add((time) => {
        container.rotation -= 0.01 * time.deltaTime;
      });
    }

    disconnectedCallback() {
      if (this.app) {
        this.app.destroy(true, { children: true, texture: true });
      }
    }
  }

  customElements.define('main-canvas', MainCanvas);
</script>
